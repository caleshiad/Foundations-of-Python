# Python if-else Statements

# if statements check if a specific condition is true and run the code if it is
if 10 > 5: # the if condition
    print("This condition is true.") # this code has to be indented

# logical operators can be used to evaluate wheter a statement is true ( ==, !=, <, <=, >, >=)

# if-else statements choose a path depending on whether the condition is true OR false
# if-else statements are used to allow programs to make decisions by testing conditions, which allows the program to behave differently based on changing information
if 3 >= 6:
    print("This condition is true.") # code to run when the condition is true, must be indented
else:                                
    print("This condition is false.") # code to run when the condition is false, must be indented

# Variable Storing the server status
server_online = True

# Evaluate the condition and perform an if-else
if server_online == False:
    print("The server is operating normally.")
else:
    print("The server is offline. Please investigate the issue.")

# Conditional statements include if, elif, and else. They help control the program's flow.
# using variables with the if conditional statement allows a program to be flexible by making decisions based off changing information
# the if statement will check the most recently stored value for the variable 
# this allows the program to behave differently without altering the code 

minutes_exercised = int(input("How many minutes did you exercise today?")) #the output changes based on the users input 
if minutes_exercised >= 60:
    print("Well done! You've hit the daily amount of exercise needed.")
else:
    print("You are below the daily minimum for daily exercise minutes.")  


points = int(input("User Points:"))
if points > 150:
    print("Congratulations! You may unlock the reward")
    points = points - 150
    print("New Points Balance:", points)
else:
    print("Sorry, you don't have enough points for the reward right now.")
    points_needed = 150 - points 
    print (f" You need {points_needed} more points to unlock the reward.")


# elif means else if
# elif checks additional conditions after an initial if statement, if the first if is false it moves to the elif condition and tests it
# multiple elif statements can be used in a row 

temperature = 75 
if temperature > 85:
    print("It's hot outside.")
elif temperature > 60: 
    print("It's warm outside.")
else:
    print("It's cool outside.")


# Flowcharts are useful for when multiple decisions need to be considered, which translates over to if-elif-else statements
# Consider the logic of your if-elif-else statements by thinking about the conditions in order, start with the most specific or simplest requirement

user_age = int(input("How old are you?"))
if user_age <= 12:
    print("You are a child.")
elif user_age == 13:
    print("You are a preteen.")
elif 18 > user_age > 13:
    print("You are a teenager.")
elif 65 > user_age >= 18:
    print("You are an adult.")
else:
    print("You are a senior citizen.")

# a loop is a programming structure that repeats a block of code multiple times as long as a specified condition remains true or it cycles through items in a sequence 
# allows the same instructions to run repeatedly without requiring the code to be rewritten each time 

# 2 types of loops in Python: 
# while loop 
# for loop 

# a while loop repeats code as long as a condition remains true 
# used when the number of reptitions is not known in advance and depends on something changing during the program
count = 1
while count <= 3:
    print("Hello")
    count = count + 1
# the loop prints Hello 3 times b/c it repeats as long as count is less than or equal to 3

# a for loop repeats code for every item in a sequence such as a list, string, or range
for item in [1, 2, 3]:
    print(item) #the loop goes through each number in the list and prints it

# this script outputs the numbers 1-10 and then stops at 10
number = 1
while number <= 10:
    print(number)
    number = number + 1

countdown = 5                                   # this is your starting number
while countdown > 0:                            # this begins the while loop
    print("Counting down:", countdown)          # this line runs each time the loop is repeated
    countdown = countdown - 1                   # this line runs during each repititon and decreases the countdown value by 1 moving the loop closer to stopping
print("Blast Off!")                             # this line runs after the loop ends b/c the condition countdown > 0 becomes False


# This script tracks the number of login attempts before a user account is locked 

#Variable representing remaining login attempts
remaining_attempts = 3

#While loop that runs as long as attempts remain
while remaining_attempts > 0:
    print("Remainging login attempts:", remaining_attempts)
    remaining_attempts = remaining_attempts - 1
print("Account locked due to too many failed login attempts")

# define the loop variable during the for loop instead of before it to keep code clear and avoid unexpected overwriting of existing variables
numbers = [45, 62, 18, 90, 33]
for num in numbers: 
    if num < 30:
        print("Found a value less than 30:", num)
# the script creates a list of numbers and looks through each value one at a time using a loop, when it finds a number that is less than 30 it prints the message showing the value was found

# the variable in a for loop is a placeholder that temporarily stores each item from the iterable as the loop runs
# during each iteration the loop assigns the next item in the sequence to that variable, allowing the code inside the loop to use it
# the variable can be defined for the first time in the for loop header, if a variable with the same name already exists the loop will reuse and update it during each iteration
# the variable only takes on one value at a time and changes automatically as the loop progresses 

item = "placeholder"
for item in ["apple", "banana", "cherry", "strawberry", "kiwi"]:
    print(item)

# the iterable in a for loop is the collection ot sequence that the loop goes through one item at a time (string, tuple, dictionary, range, or any object that can return items in sequence)
# break is a keyword used to stop a loop early before it would finish on its own
# break ends the loop and advances the program to the line following the loop

# break should be used when: 
# find what you're looking for and no longer need to continue the loop 
# a specific condition makes continuing unnecessary or incorrect 
# you want to exit a loop as soon as a problem or invalid value is detected 

numbers = [3, 7, 12, 5, 9]
for num in numbers:
    if num > 10:
        print("Found a number greater than 10:", num)
        break
    # the loop will stop immediately when a number greater than 10 is found

# continue is a keywork that skips the rest of the current loop and moves to the next iteration 
# when python sees continue inside of a for or while loop it stops executing any remaining code in that loop for that cycle and jumps back to the top of the loop to check the next value or condition 

for number in range (5):
    if number == 2:
        continue
    print(number)  
# when number == 2 the contunue statement runs to print(number) is skipped for that iteration, the loop continues with the next value
# continue skips one loop cycle without stopping the entire loop 

numbers = [2, 4, 6, 8]
for num in numbers:
    doubled = num * 2
    print("Original:", num, "Doubled:", doubled)
# this loop retrieves each number from the list, calculates its doubled value and prints the original and the result

# Use a Loop to Manipulate a List 

numbers = [1, 2, 3, 4]
squares = []

for num in numbers:
    squares.append(num**2)

print("Original:", numbers)
print("Squared:", squares)
# the loop goes through each number, doubles it, and stores the result in a new list 

# update an existing list instead of creating a new one

grades = [88, 84, 92] 
print("original grades:", grades) # prints the original list so you can see starting values
for i in range (len(grades)):     # for loop uses range (len(grades)) to loop through index positions of the list
    grades[i] = grades[i] + 5     # inside the loop each grade is increased by 5 and stored back into the same position in the list, which updates the original list instead of making a new one
print("new grades:", grades)      # the updated list is printed after the loop finishes

# Using a for loop to iterate through a Dictionary 

student_grades = {"Alice": 90, "Bob": 85, "Carlos": 78}
for name in student_grades:
    grade = student_grades[name]
    print(name, "has a grade of", grade)

# Using Dictionary Pairs

fees = {"registration": 25.00, "lab": 40.50, "technology": 15.25}
for fee in fees: 
    fees[fee] = fees[fee] + 0.75
print(fees)
# this script increases every value in the dictionary by 0.75 and then prints the updated dictionary 

